# ─────────────────────────────────────────────────────────────────
# .gitignore — Student Performance Predictor
# ─────────────────────────────────────────────────────────────────

# Virtual environment — never push this
venv/
.venv/
env/

# Python cache — auto-generated, not needed
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Jupyter checkpoints
.ipynb_checkpoints/
*.ipynb_checkpoints


# Environment variables — may contain secrets
.env
.env.local

# VS Code settings
.vscode/
*.code-workspace

# OS generated
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini

# Logs
*.log
logs/

# Distribution / packaging
dist/
build/
*.egg-info/

# Pytest
.pytest_cache/
.coverage
htmlcov/