# Virtual environment — never goes in Docker
venv/
.venv/

# Git files
.git/
.gitignore

# Python cache
__pycache__/
*.py[cod]
*.pyo

# Jupyter checkpoints
.ipynb_checkpoints/
notebooks/

# Model binaries (regenerated inside container)
model/*.pkl

# VS Code
.vscode/

# OS files
.DS_Store
Thumbs.db

# Logs
*.log

# Readme & docs (not needed at runtime)
README.md